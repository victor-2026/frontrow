{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules", "ios", "android", ".expo", "dist", "web-build"]
}
